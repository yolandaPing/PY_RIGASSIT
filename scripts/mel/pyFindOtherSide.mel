global proc string pyFindOtherSide(string $joint, string $lKeyA[], string $rKeyA[]) {
    // 硐潰脤酘壽瑩趼
    for ($side = 0; $side < size($lKeyA); $side++) {
        if (`gmatch $joint ("*"+$lKeyA[$side]+"*")`) {
            return `substitute $lKeyA[$side] $joint $rKeyA[$side]`;
        }
    }
    return "";
}